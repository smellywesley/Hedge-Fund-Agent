# Terminal Alpha — local development
# Phase 1 uses mock data only. No API keys required.

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
API_PORT=8000

# Phase 2+ (unused in MVP shell)
DATABASE_URL=postgresql://terminal:terminal@localhost:5432/terminal_alpha
REDIS_URL=redis://localhost:6379/0

# Optional keyed connectors — each activates its feature when set; the app
# runs fine (blocked-not-faked) without them.
# ANTHROPIC_API_KEY=      # enables the live "Run Research" button (your tokens/press)
# RESEARCH_MODEL=claude-sonnet-4-5   # override if your account uses a different model id
# FMP_API_KEY=            # free tier → real growth_momentum (analyst estimates)
# FRED_API_KEY=           # real macro series (regime already works without it)
# ALLOWED_ORIGINS=https://your-app.vercel.app   # CORS for the deployed frontend
